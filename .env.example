# SafeRoute Environment Variables
# Copy this file to .env and fill in your keys

# OpenRouteService API key - get free at https://openrouteservice.org/dev/#/signup
ORS_API_KEY=
# Groq API key - get free at https://console.groq.com
GROQ_API_KEY=

# Flask config
FLASK_ENV=development
FLASK_PORT=5001
